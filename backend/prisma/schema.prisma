enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum WorkflowExecutionStatus {
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum WorkflowNodeType {
  TRIGGER
  CONDITION
  ACTION
  APPROVAL
  TIMER
  AI_ACTION
  NOTIFICATION
  WEBHOOK
}

enum FormFieldType {
  TEXT
  NUMBER
  DATE
  EMAIL
  PHONE
  SELECT
  MULTI_SELECT
  CHECKBOX
  FILE
}

model Workflow {
  id          String @id @default(uuid())
  workspaceId String
  name        String
  description String?
  status      WorkflowStatus @default(DRAFT)
  definition  Json
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  executions  WorkflowExecution[]
}

model WorkflowExecution {
  id           String @id @default(uuid())
