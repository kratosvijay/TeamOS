  workspaceId String
  provider    String
  eventType   String
  payload     Json
  processed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([provider])
  @@index([eventType])
}

