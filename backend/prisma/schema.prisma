  LINKED_TO
}

model KnowledgeNode {
  id           String              @id @default(uuid())
  workspaceId  String
  entityType   KnowledgeEntityType
  entityId     String              @unique
  label        String
  metadata     Json
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  incomingEdges KnowledgeEdge[]     @relation("TargetNode")
  outgoingEdges KnowledgeEdge[]     @relation("SourceNode")
  collections   KnowledgeCollectionNode[]

  workspace    Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([entityType])
}

model KnowledgeEdge {
  id             String                @id @default(uuid())
  workspaceId    String
  sourceNodeId   String
  targetNodeId   String
  relationType   KnowledgeRelationType
  metadata       Json
  createdAt      DateTime              @default(now())

  sourceNode     KnowledgeNode         @relation("SourceNode", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode     KnowledgeNode         @relation("TargetNode", fields: [targetNodeId], references: [id], onDelete: Cascade)
  workspace      Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([sourceNodeId])
  @@index([targetNodeId])
}



model KnowledgeCollectionNode {
  id           String              @id @default(uuid())
  collectionId String
  nodeId       String

  collection   KnowledgeCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  node         KnowledgeNode       @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([collectionId, nodeId])
}

