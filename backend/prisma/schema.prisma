datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MANAGER
  TEAM_LEAD
  DEVELOPER
  QA
  GUEST
}

enum ProjectRole {
  LEAD
  DEVELOPER
  VIEWER
}

enum TaskType {
  EPIC
  STORY
  TASK
  BUG
  SUBTASK
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  TESTING
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ChannelType {
  GLOBAL_TEXT
  PROJECT_TEXT
  PRIVATE_TEXT
  TICKET_TEXT
  DIRECT_MESSAGE
  GLOBAL_VOICE
  PROJECT_VOICE
}

enum PresenceStatus {
  ONLINE
  OFFLINE
  AWAY
  BUSY
  IN_MEETING
  FOCUS_MODE
}

enum ChannelRole {
  OWNER
  MODERATOR
  MEMBER
}

enum MeetingStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_UPDATED
  MENTION
  PROJECT_INVITE
  MEETING_REMINDER
  MEETING_STARTED
  RECORDING_READY
  MEETING_SUMMARY_READY
  SPRINT_STARTED
  SPRINT_COMPLETED
  DOCUMENT_UPDATED
  CHAT_MESSAGE
}

enum DependencyType {
  BLOCKS
  RELATES_TO
  DUPLICATES
  DEPENDS_ON
  CAUSED_BY
  PARENT_OF
  CHILD_OF
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  SELECT
  MULTI_SELECT
  USER
  URL
}

enum BoardViewType {
  KANBAN
  LIST
  CALENDAR
  TIMELINE
  ROADMAP
}

model User {
  id                  String             @id @default(uuid())
  email               String             @unique
  passwordHash        String?
  fullName            String
  avatarUrl           String?
  googleId            String?            @unique
  microsoftId         String?            @unique
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  
  workspaces          WorkspaceMember[]
  projectMembers      ProjectMember[]
  assignedTasks       Task[]             @relation("TaskAssignee")
  reportedTasks       Task[]             @relation("TaskReporter")
  comments            TaskComment[]
  activityLogs        TaskActivity[]
  sentMessages        Message[]          @relation("MessageSender")
  meetingParticipants MeetingParticipant[]
  hostedMeetings      Meeting[]          @relation("MeetingHost")
  meetingNotes        MeetingNote[]      @relation("MeetingNoteCreator")
  meetingDecisions    MeetingDecision[]  @relation("DecisionCreator")
  meetingActionItems  MeetingActionItem[] @relation("ActionItemAssignee")
  waitingRoomEntries  MeetingWaitingRoom[] @relation("WaitingRoomUser")
  waitingRoomApprovals MeetingWaitingRoom[] @relation("WaitingRoomApprover")
  breakoutRooms       BreakoutRoomParticipant[] @relation("BreakoutRoomUser")
  documentsCreated    Document[]         @relation("DocumentCreator")
  documentsUpdated    Document[]         @relation("DocumentUpdater")
  dmRooms             DirectMessageRoomParticipant[]
  devices             Device[]
  presences           UserPresence[]
  activities          ActivityLog[]
  auditLogs           LoginAuditLog[]
  notifications       Notification[]
  mentions            Mention[]
  watchLists          TaskWatcher[]
  uploadedFiles       FileAsset[]
  workLogs            WorkLog[]
  savedFilters        SavedFilter[]
  votes               TaskVote[]
  viewPreferences     BoardViewPreference[]
  actionsHistory      AuditTrail[]
  channelMemberships  ChannelMember[]
  reactions           MessageReaction[]
  reads               MessageRead[]
  pinnedMessages      PinnedMessage[]

  @@index([email])
}

model LoginAuditLog {
  id        String   @id @default(uuid())
  userId    String
  ipAddress String?
  userAgent String?
  status    String   // SUCCESS, FAILED
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Device {
  id         String   @id @default(uuid())
  userId     String
  deviceId   String
  platform   String   // ios, android, web, windows, macos
  fcmToken   String
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
}

model UserPresence {
  id          String         @id @default(uuid())
  userId      String
  workspaceId String
  status      PresenceStatus @default(OFFLINE)
  updatedAt   DateTime       @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model Workspace {
  id          String             @id @default(uuid())
  name        String
  slug        String             @unique
  logoUrl     String?
  ownerId     String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  
  members     WorkspaceMember[]
  projects    Project[]
  invitations Invitation[]
  channels    Channel[]          @relation("WorkspaceChannels")
  presences   UserPresence[]
  activities  ActivityLog[]
  settings    WorkspaceSettings?
  featureFlags FeatureFlag[]
  fileAssets   FileAsset[]
  customFields CustomField[]
  savedFilters SavedFilter[]
  templates    TaskTemplate[]
  auditTrails  AuditTrail[]
  meetings     Meeting[]
  calendarEvents CalendarEvent[]
}

model WorkspaceSettings {
  id                  String        @id @default(uuid())
  workspaceId         String        @unique
  allowGuestUsers     Boolean       @default(true)
  allowPublicProjects Boolean       @default(true)
  defaultRole         WorkspaceRole @default(DEVELOPER)
  enableMeetings      Boolean       @default(true)
  enableDocuments     Boolean       @default(true)
  enableAI            Boolean       @default(true)
  enableChat          Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  workspace           Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model FeatureFlag {
  id          String    @id @default(uuid())
  workspaceId String
  key         String    // AI_ASSISTANT, MEETINGS, DOCUMENTS, CHAT, ANALYTICS, TIME_TRACKING
  enabled     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, key])
}

model WorkspaceMember {
  id          String        @id @default(uuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(DEVELOPER)
  status      String        @default("ACTIVE") // ACTIVE, INVITED, SUSPENDED
  joinedAt    DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model Invitation {
  id          String        @id @default(uuid())
  workspaceId String
  email       String
  role        WorkspaceRole @default(DEVELOPER)
  token       String        @unique
  expiresAt   DateTime
  createdAt   DateTime      @default(now())
  
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Project {
  id               String                 @id @default(uuid())
  workspaceId      String
  name             String
  key              String                 // e.g. TOS
  description      String?
  status           String                 @default("ACTIVE") // ACTIVE, ARCHIVED
  nextTicketNumber Int                    @default(1)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  
  workspace        Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members          ProjectMember[]
  tasks            Task[]
  sprints          Sprint[]
  channels         Channel[]              @relation("ProjectChannels")
  documents        Document[]
  meetings         Meeting[]
  kanbanSettings   KanbanColumnSetting[]
  viewPreferences  BoardViewPreference[]
  
  @@unique([workspaceId, name])
  @@unique([workspaceId, key])
  @@index([workspaceId])
}

model KanbanColumnSetting {
  id          String     @id @default(uuid())
  projectId   String
  status      TaskStatus
  wipLimit    Int        @default(0) // 0 means no limit
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, status])
}

model ProjectMember {
  id        String      @id @default(uuid())
  projectId String
  userId    String
  role      ProjectRole @default(DEVELOPER)
  createdAt DateTime    @default(now())
  
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model Sprint {
  id                       String       @id @default(uuid())
  projectId                String
  name                     String
  goal                     String?
  retrospective            String?
  retrospectiveActionItems Json?
  startDate                DateTime
  endDate                  DateTime
  isActive                 Boolean      @default(false)
  isCompleted              Boolean      @default(false)
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
  
  project                  Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks                    Task[]

  @@index([projectId])
}

model Task {
  id             String           @id @default(uuid())
  projectId      String
  sprintId       String?
  parentId       String?
  key            String           @unique // e.g., TOS-101
  title          String
  description    String?
  type           TaskType         @default(TASK)
  status         TaskStatus       @default(TODO)
  priority       TaskPriority     @default(MEDIUM)
  storyPoints    Int?
  position       Float            @default(0) // Fractional board ordering
  assigneeId     String?
  reporterId     String?
  dueDate        DateTime?
  estimatedHours Float?
  loggedHours    Float?           @default(0)
  recurrenceRule String?          // RFC-5545 rule string
  aiSummary      String?
  aiGenerated    Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  
  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint         Sprint?          @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  parent         Task?            @relation("Subtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks       Task[]           @relation("Subtasks")
  assignee       User?            @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter       User?            @relation("TaskReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  
  comments       TaskComment[]
  activities     TaskActivity[]
  channelId      String?          @unique // Link to Task Channel (Ticket Chat)
  channel        Channel?         @relation("TaskChannel", fields: [channelId], references: [id], onDelete: SetNull)
  watchers       TaskWatcher[]
  labels         TaskLabel[]
  attachments    TaskAttachment[]
  workLogs       WorkLog[]
  meetings       TaskMeeting[]
  directMeetings Meeting[]
  actionItems    MeetingActionItem[] @relation("LinkedActionItemTask")
  customFieldValues TaskCustomFieldValue[]
  votes          TaskVote[]
  
  dependencies   TaskDependency[] @relation("TaskSource")
  blockedBy      TaskDependency[] @relation("TaskTarget")

  @@index([projectId])
  @@index([sprintId])
  @@index([assigneeId])
}

model CustomField {
  id           String        @id @default(uuid())
  workspaceId  String
  name         String
  type         CustomFieldType
  required     Boolean       @default(false)
  defaultValue String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  
  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  values       TaskCustomFieldValue[]

  @@unique([workspaceId, name])
}

model TaskCustomFieldValue {
  id            String      @id @default(uuid())
  taskId        String
  customFieldId String
  value         String      // Stored as string, parsed based on field type
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  task          Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  customField   CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@unique([taskId, customFieldId])
}

model SavedFilter {
  id          String    @id @default(uuid())
  userId      String
  workspaceId String
  name        String
  filterJson  Json
  isShared    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

model TaskTemplate {
  id          String    @id @default(uuid())
  workspaceId String
  name        String
  description String?
  templateJson Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
}

model TaskVote {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  createdAt DateTime @default(now())

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
}

model BoardViewPreference {
  id        String        @id @default(uuid())
  userId    String
  projectId String
  viewType  BoardViewType @default(KANBAN)
  createdAt DateTime      @default(now())

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

model AuditTrail {
  id          String   @id @default(uuid())
  workspaceId String
  actorId     String
  action      String   // e.g. TASK_UPDATED, SPRINT_COMPLETED, ROLE_CHANGES, BULK_ACTION
  entityType  String
  entityId    String
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor       User      @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model Label {
  id          String      @id @default(uuid())
  name        String      @unique // frontend, backend, urgent, etc.
  color       String      @default("#3B82F6")
  tasks       TaskLabel[]
}

model TaskLabel {
  id        String   @id @default(uuid())
  taskId    String
  labelId   String

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label     Label    @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([taskId, labelId])
}

model TaskDependency {
  id             String         @id @default(uuid())
  sourceTaskId   String
  targetTaskId   String
  dependencyType DependencyType @default(BLOCKS)
  createdAt      DateTime       @default(now())

  sourceTask     Task           @relation("TaskSource", fields: [sourceTaskId], references: [id], onDelete: Cascade)
  targetTask     Task           @relation("TaskTarget", fields: [targetTaskId], references: [id], onDelete: Cascade)

  @@unique([sourceTaskId, targetTaskId, dependencyType])
}

model FileAsset {
  id          String           @id @default(uuid())
  workspaceId String
  uploadedById String
  fileName    String
  mimeType    String
  size        Int
  bucketPath  String
  createdAt   DateTime         @default(now())

  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  uploader    User             @relation(fields: [uploadedById], references: [id])
  tasks       TaskAttachment[]
  recordings  MeetingRecording[]
}

model TaskAttachment {
  id          String    @id @default(uuid())
  taskId      String
  fileAssetId String
  createdAt   DateTime  @default(now())

  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fileAsset   FileAsset @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)

  @@unique([taskId, fileAssetId])
}

model WorkLog {
  id          String   @id @default(uuid())
  taskId      String
  userId      String
  hours       Float
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TaskMeeting {
  id          String   @id @default(uuid())
  taskId      String
  meetingId   String
  createdAt   DateTime @default(now())

  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([taskId, meetingId])
}

model TaskWatcher {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  createdAt DateTime @default(now())

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TaskActivity {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  action    String   // e.g. "STATUS_CHANGE", "ASSIGNEE_CHANGE"
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())
  
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model Channel {
  id          String       @id @default(uuid())
  workspaceId String
  projectId   String?
  name        String
  description String?
  type        ChannelType  @default(GLOBAL_TEXT)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  workspace   Workspace    @relation("WorkspaceChannels", fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project?     @relation("ProjectChannels", fields: [projectId], references: [id], onDelete: Cascade)
  task        Task?        @relation("TaskChannel")
  messages    Message[]    @relation("ChannelMessages")
  members     ChannelMember[]
  pinnedMessages PinnedMessage[]
  
  @@unique([workspaceId, projectId, name])
  @@index([workspaceId])
  @@index([projectId])
}

model DirectMessageRoom {
  id          String       @id @default(uuid())
  createdAt   DateTime     @default(now())
  
  participants DirectMessageRoomParticipant[]
  messages    Message[]    @relation("DMRoomMessages")
}

model DirectMessageRoomParticipant {
  id        String            @id @default(uuid())
  roomId    String
  userId    String
  
  room      DirectMessageRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
}

model Message {
  id            String             @id @default(uuid())
  senderId      String
  channelId     String?
  dmRoomId      String?
  parentId      String?            // For Slack-style thread replies
  content       String
  attachments   MessageAttachment[]
  isVoiceNote   Boolean            @default(false)
  voiceDuration Int?               // in seconds
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  
  sender        User               @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  channel       Channel?           @relation("ChannelMessages", fields: [channelId], references: [id], onDelete: Cascade)
  dmRoom        DirectMessageRoom? @relation("DMRoomMessages", fields: [dmRoomId], references: [id], onDelete: Cascade)
  parent        Message?           @relation("ThreadReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       Message[]          @relation("ThreadReplies")
  reactions     MessageReaction[]
  reads         MessageRead[]
  pinnedMessage PinnedMessage?

  @@index([channelId])
  @@index([dmRoomId])
  @@index([parentId])
}

model ChannelMember {
  id        String      @id @default(uuid())
  channelId String
  userId    String
  role      ChannelRole @default(MEMBER)
  createdAt DateTime    @default(now())

  channel   Channel     @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String   // 👍, ❤️, 🔥, 🚀, 👀
  createdAt DateTime @default(now())

  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model MessageRead {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())

  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

model PinnedMessage {
  id         String   @id @default(uuid())
  messageId  String   @unique
  channelId  String
  pinnedById String
  createdAt  DateTime @default(now())

  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  channel    Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  pinnedBy   User     @relation(fields: [pinnedById], references: [id], onDelete: Cascade)
}

model MessageAttachment {
  id        String   @id @default(uuid())
  messageId String
  name      String
  url       String
  size      Int
  mimeType  String
  createdAt DateTime @default(now())
  
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

enum MeetingType {
  INSTANT
  SCHEDULED
  VOICE_ONLY
  TASK_DISCUSSION
  PROJECT_REVIEW
  SPRINT_PLANNING
  RETROSPECTIVE
}

enum MeetingParticipantRole {
  HOST
  CO_HOST
  PRESENTER
  ATTENDEE
}

enum MeetingActionItemStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CalendarProvider {
  GOOGLE
  OUTLOOK
  INTERNAL
}

enum RecordingStatus {
  PROCESSING
  COMPLETED
  FAILED
}

enum MeetingInsightType {
  ACTION_ITEM
  DECISION
  RISK
  BLOCKER
  FOLLOW_UP
}

model Meeting {
  id           String               @id @default(uuid())
  workspaceId  String
  projectId    String?
  taskId       String?
  title        String
  description  String?
  meetingType  MeetingType          @default(SCHEDULED)
  status       MeetingStatus        @default(SCHEDULED)
  hostId       String
  roomName     String               @unique
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  workspace    Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project      Project?             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task         Task?                @relation(fields: [taskId], references: [id], onDelete: Cascade)
  host         User                 @relation("MeetingHost", fields: [hostId], references: [id])
  participants MeetingParticipant[]
  taskMeetings TaskMeeting[]
  recordings   MeetingRecording[]
  notes        MeetingNote[]
  schedules    MeetingSchedule[]
  calendarEvents CalendarEvent[]
  actionItems  MeetingActionItem[]
  decisions    MeetingDecision[]
  transcripts  MeetingTranscript[]
  waitingRoom  MeetingWaitingRoom[]
  breakoutRooms BreakoutRoom[]
  summaries    MeetingSummary[]
  insights     MeetingInsight[]

  @@index([workspaceId])
  @@index([projectId])
  @@index([taskId])
  @@index([hostId])
}

model MeetingParticipant {
  id              String                 @id @default(uuid())
  meetingId       String
  userId          String
  role            MeetingParticipantRole @default(ATTENDEE)
  joinedAt        DateTime               @default(now())
  leftAt          DateTime?
  durationSeconds Int?

  meeting         Meeting                @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
  @@index([meetingId])
  @@index([userId])
}

model MeetingActionItem {
  id          String                  @id @default(uuid())
  meetingId   String
  title       String
  description String?
  assigneeId  String?
  dueDate     DateTime?
  status      MeetingActionItemStatus @default(OPEN)
  taskId      String?                 // For auto-linking or task conversion
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  meeting     Meeting                 @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  assignee    User?                   @relation("ActionItemAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  task        Task?                   @relation("LinkedActionItemTask", fields: [taskId], references: [id], onDelete: SetNull)

  @@index([meetingId])
  @@index([assigneeId])
  @@index([taskId])
}

model MeetingDecision {
  id          String   @id @default(uuid())
  meetingId   String
  decision    String
  createdBy   String
  createdAt   DateTime @default(now())

  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  creator     User     @relation("DecisionCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([createdBy])
}

model MeetingTranscript {
  id        String   @id @default(uuid())
  meetingId String
  content   String
  language  String   @default("en")
  createdAt DateTime @default(now())

  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
}

model MeetingWaitingRoom {
  id          String    @id @default(uuid())
  meetingId   String
  userId      String
  requestedAt DateTime  @default(now())
  approvedAt  DateTime?
  approvedBy  String?

  meeting     Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user        User      @relation("WaitingRoomUser", fields: [userId], references: [id], onDelete: Cascade)
  approver    User?     @relation("WaitingRoomApprover", fields: [approvedBy], references: [id], onDelete: SetNull)

  @@index([meetingId])
  @@index([userId])
}

model BreakoutRoom {
  id           String                    @id @default(uuid())
  meetingId    String
  name         String
  createdAt    DateTime                  @default(now())
  
  meeting      Meeting                   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  participants BreakoutRoomParticipant[]

  @@index([meetingId])
}

model BreakoutRoomParticipant {
  id             String       @id @default(uuid())
  breakoutRoomId String
  userId         String

  breakoutRoom   BreakoutRoom @relation(fields: [breakoutRoomId], references: [id], onDelete: Cascade)
  user           User         @relation("BreakoutRoomUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([breakoutRoomId, userId])
  @@index([breakoutRoomId])
  @@index([userId])
}

model MeetingRecording {
  id           String          @id @default(uuid())
  meetingId    String
  fileAssetId  String?
  duration     Int?            // in seconds
  status       RecordingStatus @default(PROCESSING)
  playbackUrl  String?
  downloadUrl  String?
  createdAt    DateTime        @default(now())

  meeting      Meeting         @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  fileAsset    FileAsset?      @relation(fields: [fileAssetId], references: [id], onDelete: SetNull)

  @@index([meetingId])
  @@index([fileAssetId])
}

model MeetingNote {
  id          String   @id @default(uuid())
  meetingId   String
  content     String
  createdBy   String
  createdAt   DateTime @default(now())

  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  creator     User     @relation("MeetingNoteCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([createdBy])
}

model MeetingSchedule {
  id             String   @id @default(uuid())
  meetingId      String
  startTime      DateTime
  endTime        DateTime
  timezone       String   @default("UTC")
  recurrenceRule String?  // RFC-5545 recurrence rule

  meeting        Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
}

model CalendarEvent {
  id              String            @id @default(uuid())
  meetingId       String?
  workspaceId     String
  title           String
  startTime       DateTime
  endTime         DateTime
  externalEventId String?
  provider        CalendarProvider? @default(INTERNAL)
  createdAt       DateTime          @default(now())

  meeting         Meeting?          @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  workspace       Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([workspaceId])
}

model MeetingSummary {
  id        String   @id @default(uuid())
  meetingId String
  summary   String
  keyPoints Json     // Stored as a JSON array of strings
  createdAt DateTime @default(now())

  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
}

model MeetingInsight {
  id        String             @id @default(uuid())
  meetingId String
  type      MeetingInsightType
  content   String
  createdAt DateTime           @default(now())

  meeting   Meeting            @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
}

model Document {
  id          String     @id @default(uuid())
  projectId   String?
  parentId    String?    // Hierarchy support
  title       String
  content     String     @default("") // Rich text / Block-based content (JSON or MD)
  isWiki      Boolean    @default(false)
  isKb        Boolean    @default(false)
  creatorId   String
  updaterId   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent      Document?  @relation("DocHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    Document[] @relation("DocHierarchy")
  creator     User       @relation("DocumentCreator", fields: [creatorId], references: [id])
  updater     User       @relation("DocumentUpdater", fields: [updaterId], references: [id])

  @@index([projectId])
  @@index([parentId])
}

model Notification {
  id          String           @id @default(uuid())
  userId      String
  type        NotificationType
  title       String
  message     String
  entityType  String           // TASK, PROJECT, MEETING, DOCUMENT, CHAT
  entityId    String
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model Mention {
  id          String   @id @default(uuid())
  userId      String
  entityType  String   // TASK_COMMENT, CHAT_MESSAGE, DOCUMENT, MEETING_NOTE
  entityId    String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ActivityLog {
  id          String   @id @default(uuid())
  workspaceId String
  userId      String
  entityType  String   // WORKSPACE, PROJECT, TASK, SPRINT, MEETING, DOCUMENT, MENTION
  entityId    String
  action      String   // CREATED, UPDATED, DELETED, STARTED, COMPLETED, SCHEDULED, ASSIGNED
  metadata    Json?
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}
