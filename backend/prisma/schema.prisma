}

model AIAutomation {
  id          String    @id @default(uuid())
  workspaceId String
  name        String
  trigger     String
  action      String
  createdAt   DateTime  @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

