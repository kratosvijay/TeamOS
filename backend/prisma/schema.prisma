enum IntegrationPermission {
  READ_ONLY
  READ_WRITE
  ADMIN
}

enum IntegrationSyncStatus {
  SYNC_PENDING
  SYNCING
  SYNCED
  FAILED
  PAUSED
}

model Integration {
  id           String   @id @default(uuid())
  workspaceId  String
  provider     String   // e.g. GITHUB, GITLAB, GOOGLE, MICROSOFT, SLACK, TEAMS
  name         String
  description  String?
  status       String   // ACTIVE, INACTIVE
  version      String   @default("1.0.0")
  installedAt  DateTime @default(now())
  createdAt    DateTime @default(now())

